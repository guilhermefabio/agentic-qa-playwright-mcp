# Copie este arquivo para .env e preencha com os valores reais
# cp .env.example .env
#
# Todas as variáveis abaixo podem ser substituídas por argumentos CLI:
#   --url, --user, --password, --provider, --model
# O .env serve apenas como padrão/fallback.

# --- Sistema alvo (fallback; prefira passar via --url --user --password) ---
# BASE_URL=https://url-do-sistema/login.aspx
# LOGIN_USER=usuario
# LOGIN_PASSWORD=senha

# --- Provedor LLM (openai | claude | ollama) ---
LLM_PROVIDER=openai

# Modelo opcional (se omitido usa o padrão do provedor)
# LLM_MODEL=claude-sonnet-4-6

# --- Chaves de API ---
ANTHROPIC_API_KEY=sk-ant-...   # necessário para LLM_PROVIDER=claude ou --provider claude
OPENAI_API_KEY=sk-...          # necessário para LLM_PROVIDER=openai ou --provider openai

# --- Ollama (apenas para LLM_PROVIDER=ollama ou --provider ollama) ---
# OLLAMA_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.2
